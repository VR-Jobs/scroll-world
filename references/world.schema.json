{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/scroll-world/world.schema.json",
  "title": "Scroll World project",
  "type": "object",
  "required": ["schema_version", "project", "design", "models", "generation", "sections", "quality", "delivery"],
  "properties": {
    "schema_version": {"const": 2},
    "project": {
      "type": "object",
      "required": ["brand", "provider", "workflow_mode", "theme", "architecture", "generation_limit"],
      "properties": {
        "brand": {"type": "string", "minLength": 1},
        "provider": {"enum": ["doubao", "higgsfield"], "default": "doubao"},
        "workflow_mode": {"enum": ["detailed", "fast"], "default": "detailed"},
        "theme": {"enum": ["low-poly-clay", "chrome-futurism", "editorial-brutalism", "glass-laboratory", "cosmic-ritual", "architectural-white"]},
        "architecture": {"enum": ["A", "B"]},
        "generation_limit": {"type": "integer", "minimum": 1}
      }
    },
    "design": {
      "type": "object",
      "required": ["style_prompt", "palette", "material", "typography", "motion", "text_strategy"],
      "properties": {
        "style_prompt": {"type": "string", "minLength": 1},
        "palette": {"type": "array", "minItems": 3, "items": {"type": "string"}},
        "material": {"type": "string"},
        "typography": {"type": "string"},
        "motion": {"type": "string"},
        "text_strategy": {"type": "string"}
      }
    },
    "models": {
      "type": "object",
      "required": ["image", "video_preview", "video_final"]
    },
    "generation": {
      "type": "object",
      "required": ["ratio", "duration_seconds", "preview_enabled"],
      "properties": {
        "ratio": {"enum": ["21:9", "16:9", "4:3", "1:1", "3:4", "9:16"]},
        "duration_seconds": {"type": "integer", "minimum": 4, "maximum": 15},
        "preview_enabled": {"type": "boolean"}
      }
    },
    "sections": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "still_prompt", "video_prompt", "outputs", "qa"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
          "still_prompt": {"type": "string"},
          "video_prompt": {"type": "string"},
          "reference_images": {"type": "array", "maxItems": 9, "items": {"type": "string"}},
          "outputs": {
            "type": "object",
            "required": ["still", "raw_final", "final_last_frame", "final_video", "mobile_video", "poster", "mobile_poster"]
          },
          "qa": {
            "type": "object",
            "required": ["must_include", "must_not_include"],
            "properties": {
              "must_include": {"type": "array", "items": {"type": "string"}},
              "must_not_include": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "video_prompt", "outputs"],
        "properties": {
          "id": {"type": "string"},
          "video_prompt": {"type": "string"},
          "outputs": {"type": "object"}
        }
      }
    },
    "pricing": {"type": "object"},
    "quality": {
      "type": "object",
      "properties": {
        "require_semantic_approval": {"type": "boolean"},
        "require_browser_qa": {"const": true},
        "still_alignment_warn_below": {"type": "number", "minimum": 0, "maximum": 1},
        "motion_jump_warn_ratio": {"type": "number", "minimum": 0}
      }
    },
    "delivery": {
      "type": "object",
      "required": ["output_dir", "public_files", "budgets"],
      "properties": {
        "output_dir": {"type": "string"},
        "portable": {
          "type": "object",
          "properties": {
            "entry": {"type": "string", "pattern": "^[^/\\\\].*\\.html$"},
            "direct_video": {"const": true},
            "require_relative_assets": {"const": true}
          }
        },
        "initial_files": {"type": "array", "items": {"type": "string"}},
        "public_files": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "budgets": {"type": "object"}
      }
    }
  }
}
